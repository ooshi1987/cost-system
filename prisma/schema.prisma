generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// SaaS層
// ─────────────────────────────────────────

// テナント（会社）― Stripe課金の単位
model Tenant {
  id                    String    @id @default(cuid())
  name                  String                       // 会社名
  email                 String    @unique            // 管理者メールアドレス
  // Stripe
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  subscriptionStatus    String?                      // active | trialing | past_due | canceled
  plan                  String    @default("free")   // free | basic | pro
  isInternal            Boolean   @default(false)    // 社内アカウント（課金スキップ・pro扱い）
  pricePerStore         Int?                         // 1店舗あたりの月額（円）
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users                 User[]
  stores                Store[]

  @@index([email])
}

// ユーザー
model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String    @unique
  passwordHash  String
  name          String?
  role          String    @default("store_staff")    // tenant_admin | store_staff
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeUsers    StoreUser[]

  @@index([tenantId])
  @@index([email])
}

// ユーザーと店舗の紐付け（多対多）
model StoreUser {
  userId    String
  storeId   String

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@index([userId])
  @@index([storeId])
}

// 店舗
model Store {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeUsers    StoreUser[]
  ingredients   Ingredient[]
  menuItems     MenuItem[]
  deliverySlips DeliverySlip[]
  settings      Settings[]

  @@index([tenantId])
}

// スーパー管理者（運営者自身）
model SuperAdmin {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
}

// ─────────────────────────────────────────
// 業務データ層（全てstoreIdで分離）
// ─────────────────────────────────────────

// 食材・調味料
model Ingredient {
  id            String    @id @default(cuid())
  storeId       String
  name          String
  unit          String                               // "g" | "ml" など
  costPerUnit   Float                                // 円/g or 円/ml
  type          String    @default("food")           // "food" | "seasoning"
  category      String?
  sortOrder     Int?
  priceSource   String    @default("manual")         // "delivery" | "manual" | "unset"
  lastUpdated   DateTime  @updatedAt

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipeItems   RecipeItem[]
  deliveryItems DeliveryItem[]

  @@unique([storeId, name])   // 同じ店舗内でのみユニーク
  @@index([storeId])
  @@index([storeId, type])
  @@index([storeId, sortOrder])
}

// メニュー商品
model MenuItem {
  id            String    @id @default(cuid())
  storeId       String
  name          String
  sellingPrice  Float                                // 販売価格（円）
  category      String?
  sortOrder     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipeItems   RecipeItem[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([storeId, sortOrder])
}

// レシピ明細（メニュー × 食材）
model RecipeItem {
  id            String    @id @default(cuid())
  menuItemId    String
  ingredientId  String
  quantity      Float

  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredient    Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
}

// アプリ設定（店舗ごと）
model Settings {
  id        String  @id @default(cuid())
  storeId   String
  key       String
  value     String

  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, key])
  @@index([storeId])
}

// 納品書
model DeliverySlip {
  id            String    @id @default(cuid())
  storeId       String
  photoPath     String?
  ocrRawData    String?
  vendor        String?                              // 取引先名（OCR抽出 or 手入力）
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deliveryItems DeliveryItem[]

  @@index([storeId])
  @@index([storeId, createdAt])
}

// 納品書明細
model DeliveryItem {
  id              String    @id @default(cuid())
  deliverySlipId  String
  ingredientId    String
  quantity        Float
  unit            String
  totalPrice      Float

  deliverySlip    DeliverySlip  @relation(fields: [deliverySlipId], references: [id], onDelete: Cascade)
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([deliverySlipId])
  @@index([ingredientId])
}

// パスワードリセットトークン
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// 問い合わせ
model ContactInquiry {
  id          String    @id @default(cuid())
  category    String                          // "usage" | "bug" | "billing" | "feature" | "other"
  content     String
  email       String?                         // ログイン中ならテナントのメール、未ログインはnull
  tenantId    String?                         // ログイン中なら自動付与
  tenantName  String?                         // ログイン中なら自動付与
  plan        String?                         // ログイン中なら自動付与
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([isRead])
  @@index([createdAt])
}
